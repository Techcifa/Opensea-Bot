# ============================================================
# NFT MINTER CONFIG — Copy this file to .env and fill in values
# ============================================================

# --- SYSTEM CONTRACTS (DO NOT CHANGE) ---
SEA_DROP_ADDRESS="0x00005EA00Ac477B1030CE78506496e8C2dE24bf5"
MULTIMINT_ADDRESS="0x0000419B4B6132e05DfBd89F65B165DFD6fA126F"

# --- NETWORK SELECTION ---
# Options: ETH, BASE, OP, ARB, POLY, AVAX, BSC
NETWORK="ETH"

# --- TARGET MINTING ---
NFT_CONTRACT_ADDRESS="0xYourNFTContractAddressHere"
MINT_QUANTITY="1"

# --- TIME SNIPER ---
# Set 'true' to ignore the start timer and mint immediately
FORCE_START=false

# --- MINTING MODE ---
# PROXY = route via MultiMint contract (default)
# DIRECT = call the NFT contract function directly
MINT_MODE="DIRECT"
# Only for DIRECT mode. Common values: mint, publicMint, purchase, claim
MINT_FUNC_NAME="mint"

# --- PERFORMANCE ---
MAX_WORKERS="5"
RETRY_DELAY_MIN="1.5"
RETRY_DELAY_MAX="3.0"

# --- GAS SETTINGS ---
# Leave blank for automatic EIP-1559 calculation.
# Enter a number (e.g. 5) to force a specific Gwei for legacy transactions.
GAS_PRICE_GWEI=""

# Maximum Gwei limit. Bot PAUSES if network gas exceeds this.
MAX_GAS_LIMIT="50"
# Gwei ceiling — workers queue instead of firing when exceeded
GAS_CEILING_GWEI="80"

# --- GAS STRATEGY ---
# Multiplier for the current Base Fee (e.g. 1.25 = 25% buffer). 
# Higher = faster confirmation, but requires more balance.
GAS_BASE_FEE_MULTIPLIER="1.10"
# Priority fee to tip miners (in Gwei). Default is 1.5.
PRIORITY_FEE_GWEI="1.00"
# Extra fee buffer applied in execution after oracle (1.0 = no extra padding).
TX_FEE_BUFFER_MULTIPLIER="1.0"
# Buffer for gas-limit estimate (1.1 = 10% headroom).
GAS_ESTIMATE_MULTIPLIER="1.1"

# --- GOD MODE (PRE-SIGNED TX) ---
# Pre-calculates and signs the TX 5 seconds before mint opens. Broadcasts at T-0.
PRE_SIGN_ENABLED=false
# Gas multiplier for pre-signed TX (2.0 = 2x current gas price, avoids stuck TX)
PRE_SIGN_GAS_MULTIPLIER="2.0"
# Hardcoded gas limit for pre-sign (estimates often fail before mint opens)
PRE_SIGN_GAS_LIMIT="300000"

# --- FLASHBOTS (PRIVATE MEMPOOL) ---
# Route transactions through Flashbots Relay to prevent frontrunning/sandwich attacks
FLASHBOTS_MODE=false

# --- GAS BUMPING ---
# If a TX hasn't confirmed after this many blocks, resubmit with +12% priority fee
BUMP_AFTER_BLOCKS="3"
# Maximum gas bump multiplier (1.5 = cap at 1.5x original gas)
MAX_GAS_BUMP_MULTIPLIER="1.5"

# --- PROXY SETTINGS ---
# Set 'true' to rotate through proxies from proxies.txt
USE_PROXIES=false

# --- AUTO FUNDER ---
AUTO_FUND_ENABLED=false
# Master wallet private key that tops up workers
MASTER_PRIVATE_KEY="0xYourMasterPrivateKeyHere"
# Minimum ETH balance a worker must have (will be topped up if below)
MIN_WORKER_BALANCE="0.005"
# Amount to send when topping up
FUNDING_AMOUNT="0.01"

# --- WALLET CLEANER (DUST SWEEPER) ---
# Withdraw remaining ETH back to master after minting
AUTO_SWEEP_ETH=false
MIN_ETH_TO_SWEEP="0.005"

# --- AUTO TRANSFER / CONSOLIDATION ---
# Send minted NFTs to a cold wallet after each successful mint
AUTO_TRANSFER_ENABLED=false
RECIPIENT_ADDRESS="0xYourColdWalletAddressHere"

# --- WORKER PRIORITY ---
# Comma-separated priority tiers per wallet index (1=highest). E.g. "1,1,2,2,3" for 5 wallets
WORKER_PRIORITY=""

# --- DEAD LETTER QUEUE ---
RETRY_LIMIT="3"
RETRY_DELAY_S="5"

# --- POST-MINT AUTO-LIST ---
# If set, automatically list minted NFT on OpenSea at this price (in ETH) after a successful mint
POST_MINT_LIST_PRICE=""

# --- TRAIT SNIPING ---
# Rarity rank threshold — flag minted tokens below this rank in the dashboard
RARITY_THRESHOLD=""

# --- NOTIFICATION SYSTEM ---
DISCORD_ENABLED=false
DISCORD_WEBHOOK_URL="https://discord.com/api/webhooks/xxxx/xxxx"

# --- THE ACCOUNTANT (BOOKKEEPING) ---
ACCOUNTANT_ENABLED=false

# --- ANTI-HONEYPOT VERIFIER ---
VERIFY_CONTRACT_ENABLED=false
# Get a free API key from etherscan.io/myapikey (or equivalent for your network)
EXPLORER_API_KEY="YourExplorerApiKeyHere"

# --- OPENSEA (for SEADROP_WL allowlist proof fetch) ---
OS_API_KEY="YourOpenSeaApiKeyHere"
